# Royal Ruby — local environment config
# Copy this file to `.env.local` and fill in whichever keys you have.
# `.env.local` is gitignored. Never commit real secrets.

# ---- Cross-platform post scheduler (pick ONE provider) ----

# Blotato — preferred, AI-first, multi-platform
# Sign up at https://blotato.com → Settings → API
BLOTATO_API_KEY=
BLOTATO_ACCOUNT_GROUP_ID=

# Metricool — alternative, better analytics
# https://metricool.com → Settings → API
METRICOOL_USER_TOKEN=
METRICOOL_BLOG_ID=

# Buffer — simplest, text-only on free tier
# https://buffer.com → Developers
BUFFER_ACCESS_TOKEN=
BUFFER_PROFILE_ID=

# ---- Stripe (server-side, for the creation macro ONLY) ----
# sk_live_... or sk_test_... — NEVER commit this
# Create a restricted key at https://dashboard.stripe.com/apikeys
# Minimum permissions needed: products write, prices write, payment_links write
STRIPE_SECRET_KEY=

# ---- Email sequences (pick ONE) ----
# ConvertKit — recommended for creators
# https://app.convertkit.com/account_settings/advanced_settings
CONVERTKIT_API_SECRET=
CONVERTKIT_FORM_ID=

# Mailchimp — alternative
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ---- Deployed contract (fill in AFTER running nft/DEPLOY.md) ----
# Used by nft.html — paste the contract address from `forge create`
VITE_NFT_CONTRACT_ADDRESS=
